// For format details, see https://aka.ms/devcontainer.json.
{
    "name": "tfview",
    "build":  {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": "true",
            "username": "vscode",
            "userUid": "1000",
            "userGid": "1000",
            "upgradePackages": "false"
        },
        "./features/ocaml": {
            "packages": "bigstringaf cppo alcotest memtrace benchmark js_of_ocaml js_of_ocaml-compiler js_of_ocaml-ppx"
        },
        "./features/gh": {},
        "./features/npm": {
            "packages": "jsdom@24",
            "playwright": true
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ocamllabs.ocaml-platform",
                "anthropic.claude-code",
                "github.vscode-github-actions",
                "github.vscode-pull-request-github"
            ]
        }
    },
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached"
    ],
    "remoteUser": "vscode",
    "postCreateCommand": {
        "submodules": "git submodule update --init --depth 1",
        "opam": "sudo sh -ceux \"chown -R $(id -u):$(id -g) ${OPAMROOT}/log\""
    },
    "waitFor": "postCreateCommand"
}
