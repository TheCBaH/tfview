{
    "name": "ocaml/opam toolchains",
    "id": "ocaml",
    "version": "0.0.2",
    "description": "Install ocaml/opam toolchains",
    "options": {
        "packages": {
            "type": "string",
            "default": "",
            "description": "space-separated packages to install; use 'name#version' to pin a specific version (e.g. 'utop ocamlformat#0.28.0')"
        },
        "version": {
            "type": "string",
            "default": "4.14.2",
            "description": "OCaml version"
        },
        "options": {
            "type": "string",
            "default": "",
            "description": "OPAM switch options"
        },
        "system-packages": {
            "type": "string",
            "default": "",
            "description": "additional system packages"
        },
        "pin-packages": {
            "type": "string",
            "default": "",
            "description": "comma-separated packages to pin: use 'name#version' to pin a specific version, 'name url' or 'name version' to pin via opam pin add (e.g. 'pkg1#1.0.0,pkg2 https://repo.git#branch')"
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
