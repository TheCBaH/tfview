{
    "name": "ocaml/opam toolchains",
    "id": "ocaml",
    "version": "0.0.2",
    "description": "Install ocaml/opam toolchains",
    "options": {
        "packages": {
            "type": "string",
            "default": "",
            "description": "additional packages"
        },
        "version": {
            "type": "string",
            "default": "4.14.2",
            "description": "OCaml version"
        },
        "options": {
            "type": "string",
            "default": "",
            "description": "OPAM switch options"
        },
        "system-packages": {
            "type": "string",
            "default": "",
            "description": "additional system packages"
        },
        "pin-packages": {
            "type": "string",
            "default": "",
            "description": "comma-separated list of 'name url' pairs to pin via opam pin add (e.g. 'pkg1 https://repo.git#branch,pkg2 https://repo2.git')"
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
